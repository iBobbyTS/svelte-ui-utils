{
  "name": "@ibobbyts/svelte-ui-utils",
  "version": "0.1.2",
  "description": "Reusable Svelte 5 UI utilities for toast notifications, dropdown search, and data tables.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iBobbyTS/svelte-ui-utils.git"
  },
  "bugs": {
    "url": "https://github.com/iBobbyTS/svelte-ui-utils/issues"
  },
  "homepage": "https://github.com/iBobbyTS/svelte-ui-utils#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./toast": {
      "types": "./dist/toast/index.d.ts",
      "svelte": "./dist/toast/index.js",
      "default": "./dist/toast/index.js"
    },
    "./dropdown": {
      "types": "./dist/dropdown/index.d.ts",
      "svelte": "./dist/dropdown/index.js",
      "default": "./dist/dropdown/index.js"
    },
    "./dropdown-search": {
      "types": "./dist/dropdown-search/index.d.ts",
      "svelte": "./dist/dropdown-search/index.js",
      "default": "./dist/dropdown-search/index.js"
    },
    "./dropdown-search/state": {
      "types": "./dist/dropdown-search/state.d.ts",
      "default": "./dist/dropdown-search/state.js"
    },
    "./table": {
      "types": "./dist/data-table/index.d.ts",
      "svelte": "./dist/data-table/index.js",
      "default": "./dist/data-table/index.js"
    },
    "./pagination": {
      "types": "./dist/pagination/index.d.ts",
      "svelte": "./dist/pagination/index.js",
      "default": "./dist/pagination/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "svelte-package"
  },
  "peerDependencies": {
    "svelte": ">=5"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.5",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.9",
    "@tsconfig/svelte": "^5.0.5",
    "jsdom": "^27.3.0",
    "svelte": "^5.55.3",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.16"
  }
}
